{
  "name": "@esetnik/mssql-mcp-core",
  "version": "0.5.2",
  "description": "Shared core library for MSSQL MCP servers - tools, config, routing, and server harness (fork of @connorbritain/mssql-mcp-core)",
  "keywords": [
    "mcp",
    "sql-server",
    "mssql",
    "database",
    "ai",
    "claude",
    "windsurf",
    "model-context-protocol"
  ],
  "author": "Connor England <connor.r.england@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/esetnik/mssql-mcp-core.git"
  },
  "homepage": "https://github.com/esetnik/mssql-mcp-core",
  "bugs": {
    "url": "https://github.com/esetnik/mssql-mcp-core/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./dist/preload-driver.js": "./dist/preload-driver.js"
  },
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "watch": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:smoke": "tsx test/smoke-sinks.ts"
  },
  "files": [
    "dist"
  ],
  "devDependencies": {
    "@types/mssql": "^9.1.7",
    "@types/node": "^20.14.2",
    "tsx": "^4.19.0",
    "typescript": "^5.4.5",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@azure/identity": "^4.4.0",
    "@azure/keyvault-secrets": "^4.9.0",
    "@modelcontextprotocol/sdk": "^1.23.0",
    "dotenv": "^16.4.5",
    "mssql": "^10.0.1"
  },
  "optionalDependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.992.0",
    "@aws-sdk/client-secrets-manager": "^3.700.0",
    "msnodesqlv8": "^5.1.5"
  },
  "peerDependenciesMeta": {
    "msnodesqlv8": {
      "optional": true
    }
  },
  "type": "module"
}
